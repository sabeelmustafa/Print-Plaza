rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isEmailVerified() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == 'sabeelchakwal@gmail.com'
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- User Validation ---
    function isValidUser(data) {
      return data.keys().hasAll(['id', 'email', 'role']) &&
             data.keys().size() == 5 && // id, email, role, displayName, createdAt
             data.id == request.auth.uid &&
             data.email == request.auth.token.email &&
             data.role in ['admin', 'client'] &&
             data.role == (isAdmin() ? data.role : 'client') &&
             data.createdAt is timestamp;
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if (isAdmin() || (isOwner(userId) && incoming().role == existing().role)) && isValidUser(incoming());
    }

    // --- Product Validation ---
    function isValidProduct(data) {
      return data.keys().hasAll(['id', 'name', 'price', 'unit', 'categoryId']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.price is number && data.price >= 0 &&
             data.unit is string && data.unit.size() > 0 &&
             data.categoryId is string;
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin() && isValidProduct(incoming());
    }

    // --- Order Validation ---
    function isValidOrder(data) {
      return data.keys().hasAll(['id', 'userId', 'productId', 'quantity', 'status']) &&
             data.userId == request.auth.uid &&
             data.status in ['pending', 'processing', 'completed', 'cancelled'] &&
             data.quantity is number && data.quantity > 0 &&
             data.totalPrice is number &&
             data.createdAt is timestamp;
    }

    match /orders/{orderId} {
      allow get: if isOwner(existing().userId) || isAdmin();
      allow list: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && isValidOrder(incoming()) && incoming().status == 'pending';
      allow update: if isAdmin() && (
        incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt'])
      );
    }

    // Admin explicit markers
    match /admins/{userId} {
      allow read: if isSignedIn();
      allow write: if false; // Managed manually or via specific tools
    }
  }
}
