# cPanel/Passenger provides PORT automatically. Use 3000 only for local tests.
PORT=3000

# MySQL database created in cPanel.
DB_HOST=localhost
DB_PORT=3306
DB_NAME=cpaneluser_printplaza
DB_USER=cpaneluser_printplaza_user
DB_PASSWORD=replace_with_database_password
DB_CONNECTION_LIMIT=10

# Admin login for CMS actions. Use long random values in production.
ADMIN_PASSWORD=replace_with_strong_admin_password
ADMIN_SESSION_SECRET=replace_with_long_random_session_secret

# Optional server-to-server admin API secret for scripts/migrations.
ADMIN_API_SECRET=replace_with_long_random_secret

# Public URL for links, emails, and future callbacks.
APP_URL=https://printplaza.net
